<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WeatherPoc2.Core.ViewModels;assembly=WeatherPoc2.Core"
             x:Class="WeatherPoc2.App.Views.CurrentConditionsPage"
             x:DataType="vm:CurrentConditionsViewModel"
             Title="Weather">
    <!-- Always-available magnifying-glass action → back to Location Search (Reqs 19 / 21). -->
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="🔍 Search" Command="{Binding OpenSearchCommand}" />
    </ContentPage.ToolbarItems>
    <VerticalStackLayout Padding="24" Spacing="16">
        <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" />

        <!-- header: icon + condition + temperature -->
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14" VerticalOptions="Center">
            <Image Grid.Column="0" Source="{Binding IconSource}" HeightRequest="56" WidthRequest="56" />
            <Label Grid.Column="1" Text="{Binding ConditionText}" VerticalOptions="Center" FontSize="18" />
            <Label Grid.Column="2" Text="{Binding TemperatureDisplay}" VerticalOptions="Center" FontSize="40" />
        </Grid>

        <!-- stacked measures -->
        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="10">
            <Label Grid.Row="0" Grid.Column="0" Text="Chance of rain" />
            <Label Grid.Row="0" Grid.Column="1" Text="{Binding ChanceOfRainDisplay}" />
            <Label Grid.Row="1" Grid.Column="0" Text="Wind speed" />
            <Label Grid.Row="1" Grid.Column="1" Text="{Binding WindSpeedDisplay}" />
        </Grid>

        <Label Text="{Binding ErrorMessage}" TextColor="Red" HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>
