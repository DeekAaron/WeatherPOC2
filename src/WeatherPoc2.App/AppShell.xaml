<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:WeatherPoc2.App.Views"
       x:Class="WeatherPoc2.App.AppShell"
       FlyoutBehavior="Disabled">
    <!-- Launch default is the FIRST item: with nothing loaded the Search screen fills the app (Req 20).
         The Route= values MUST match the "//search" / "//current" strings in MauiNavigator (Seam 3). -->
    <ShellContent Title="Search" Route="search"
                  ContentTemplate="{DataTemplate views:LocationSearchPage}" />
    <ShellContent Title="Weather" Route="current"
                  ContentTemplate="{DataTemplate views:CurrentConditionsPage}" />
</Shell>
